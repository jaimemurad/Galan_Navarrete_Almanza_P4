<Window x:Class="GestorProductosWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GestorProductosWPF"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <TabControl>
            <TabItem Header="Inventario">
                <Grid Background="#F0F4F8">
                    <DataGrid x:Name="dataGridProductos" 
                          AutoGenerateColumns="True" 
                          CanUserAddRows="False" 
                          CanUserDeleteRows="False" 
                          IsReadOnly="True" 
                          HorizontalAlignment="Stretch" 
                          VerticalAlignment="Stretch" 
                          Margin="20" 
                          RowHeaderWidth="0" 
                          AlternatingRowBackground="#E8EEF3" 
                          GridLinesVisibility="Horizontal" 
                          BorderBrush="#D1D9E6" 
                          BorderThickness="1">
                        <DataGrid.Resources>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#007ACC"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            </Style>
                            <Style TargetType="DataGridCell">
                                <Setter Property="BorderBrush" Value="#D1D9E6"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            </Style>
                        </DataGrid.Resources>
                    </DataGrid>
                    <Button x:Name="btnAgregar" Content="Agregar" 
                        HorizontalAlignment="Left" 
                        Margin="69,178,0,0" 
                        VerticalAlignment="Top" 
                        Height="39" 
                        Width="190" 
                        Background="#007ACC" 
                        Foreground="White" 
                        FontWeight="Bold" 
                        BorderBrush="#005A9E" 
                        BorderThickness="1" 
                        Click="btnAgregar_Click"/>
                    <Button x:Name="btnEliminar" Content="Eliminar" 
                        HorizontalAlignment="Left" 
                        Margin="547,178,0,0" 
                        VerticalAlignment="Top" 
                        Height="39" 
                        Width="190" 
                        Background="#D32F2F" 
                        Foreground="White" 
                        FontWeight="Bold" 
                        BorderBrush="#B71C1C" 
                        BorderThickness="1" 
                        Click="btnEliminar_Click"/>
                </Grid>
            </TabItem>
            <TabItem Header="Busqueda">
                <Grid Background="#F0F4F8">
                    <ComboBox x:Name="comboTipoBusqueda" 
                          HorizontalAlignment="Center" 
                          Margin="0,10,0,0" 
                          VerticalAlignment="Top" 
                          Width="668" 
                          Height="34" 
                          Background="#E8EEF3" 
                          BorderBrush="#D1D9E6"/>
                    <TextBox x:Name="txtBusqueda" 
                         HorizontalAlignment="Center" 
                         Margin="0,75,0,0" 
                         TextWrapping="Wrap" 
                         Text="Producto" 
                         VerticalAlignment="Top" 
                         Width="668" 
                         Height="38" 
                         Background="#FFFFFF" 
                         BorderBrush="#D1D9E6"/>
                    <Button x:Name="btnBuscar" Content="Buscar" 
                        HorizontalAlignment="Left" 
                        Margin="503,141,0,0" 
                        VerticalAlignment="Top" 
                        Height="34" 
                        Width="228" 
                        Background="#007ACC" 
                        Foreground="White" 
                        FontWeight="Bold" 
                        BorderBrush="#005A9E" 
                        BorderThickness="1" 
                        Click="btnBuscar_Click_1"/>
                    <TextBlock x:Name="txtResultadoBusqueda" 
                           HorizontalAlignment="Left" 
                           Margin="63,145,0,0" 
                           TextWrapping="Wrap" 
                           Text="Resultado" 
                           VerticalAlignment="Top" 
                           Height="136" 
                           Width="305" 
                           Foreground="#333333" 
                           FontWeight="Bold"/>
                    <ProgressBar x:Name="progressIteraciones" 
                             HorizontalAlignment="Left" 
                             Height="50" 
                             Margin="503,213,0,0" 
                             VerticalAlignment="Top" 
                             Width="228" 
                             Foreground="#007ACC" 
                             Background="#E8EEF3"/>
                </Grid>
            </TabItem>
            <TabItem Header="Ordenamiento">
                <Grid Background="#F0F4F8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="103*"/>
                        <ColumnDefinition Width="691*"/>
                    </Grid.ColumnDefinitions>
                    <ComboBox x:Name="comboCriterioOrden" 
                          HorizontalAlignment="Left" 
                          Margin="69,29,0,0" 
                          VerticalAlignment="Top" 
                          Width="656" 
                          Height="40" 
                          Background="#E8EEF3" 
                          BorderBrush="#D1D9E6" 
                          Grid.ColumnSpan="2"/>
                    <Button x:Name="btnOrdenar" Content="Ordenar" 
                        HorizontalAlignment="Left" 
                        Margin="386,101,0,0" 
                        VerticalAlignment="Top" 
                        Height="44" 
                        Width="236" 
                        Background="#007ACC" 
                        Foreground="White" 
                        FontWeight="Bold" 
                        BorderBrush="#005A9E" 
                        BorderThickness="1" 
                        Click="btnOrdenar_Click" 
                        Grid.Column="1"/>
                    <ListView x:Name="listViewOrdenados" 
                          d:ItemsSource="{d:SampleData ItemCount=5}" 
                          Margin="69,101,354,97" 
                          Grid.ColumnSpan="2" 
                          Background="#FFFFFF" 
                          BorderBrush="#D1D9E6">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                    <Canvas x:Name="canvasGrafico" 
                        Margin="386,185,69,99" 
                        Grid.Column="1" 
                        Background="#E8EEF3">
                        <Rectangle Height="102" 
                               Canvas.Left="103" 
                               Stroke="Black" 
                               Canvas.Top="10" 
                               Width="30" 
                               HorizontalAlignment="Center" 
                               VerticalAlignment="Center"/>
                    </Canvas>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
