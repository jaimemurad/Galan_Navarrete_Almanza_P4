<Window x:Class="GestorProductosWPF.AgregarProductoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GestorProductosWPF"
        mc:Ignorable="d"
        Title="AgregarProductoWindow" Height="450" Width="800">
    <Grid>
        <TextBox x:Name="txtID" HorizontalAlignment="Left" Margin="42,39,0,0" TextWrapping="Wrap" Text="Id" VerticalAlignment="Top" Width="248" Height="27"/>
        <TextBox x:Name="txtNombre" HorizontalAlignment="Left" Margin="42,91,0,0" TextWrapping="Wrap" Text="Nombre" VerticalAlignment="Top" Width="248" Height="27"/>
        <TextBox x:Name="txtCodigoBarras" HorizontalAlignment="Left" Margin="42,144,0,0" TextWrapping="Wrap" Text="Codigo de Barras" VerticalAlignment="Top" Width="248" Height="27"/>
        <TextBox x:Name="txtCategoria" HorizontalAlignment="Left" Margin="42,0,0,0" TextWrapping="Wrap" Text="Categoria" VerticalAlignment="Center" Width="248" Height="27"/>
        <TextBox x:Name="txtPrecio" HorizontalAlignment="Left" Margin="42,256,0,0" TextWrapping="Wrap" Text="Precio" VerticalAlignment="Top" Width="248" Height="27"/>
        <TextBox x:Name="txtStock" HorizontalAlignment="Left" Margin="42,309,0,0" TextWrapping="Wrap" Text="Stock" VerticalAlignment="Top" Width="248" Height="27"/>
        <Button x:Name="btnGuardar" Content="Guardar" HorizontalAlignment="Left" Margin="480,141,0,0" VerticalAlignment="Top" Height="51" Width="192" Click="btnGuardar_Click"/>

    </Grid>
</Window>
